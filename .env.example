# =============================================================
# Vencer — Environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.
# =============================================================

# --- Supabase (database + auth) ---
# Get from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key-keep-secret...

# --- Resend (transactional email — notification on new submissions) ---
# Get from resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# Sender address for notification emails. Leave unset and emails will send from
# Resend's `onboarding@resend.dev` (works immediately, no DNS setup required).
# Once you've verified vencer.dev in Resend, switch this to:
#   EMAIL_FROM=Vencer Inbox <inbox@vencer.dev>
# EMAIL_FROM=Vencer Inbox <inbox@vencer.dev>

# --- Admin allowlist ---
# Only this email can log into /admin. Magic link logins from any
# other address are rejected by middleware.
ADMIN_EMAIL=alain@vencer.dev

# Where the inbox sends notification emails when new submissions arrive
NOTIFICATION_EMAIL=alain@vencer.dev

# --- PostHog (product analytics + session replay) ---
# Get from posthog.com → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Site URL (for absolute links in email templates) ---
NEXT_PUBLIC_SITE_URL=https://vencer.dev
